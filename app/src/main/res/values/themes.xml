<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Platform no-action-bar theme (mirrors Nightfall). All real theming is
         done in Compose; the dark window background just avoids a white flash
         before Compose draws. -->
    <style name="Theme.Lumi" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/lumi_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
